# FlipBlog environment configuration
# Copy to .env and adjust. All values have safe defaults for local dev.
# Only the values you set here override the defaults; anything omitted uses the built-in default.

# Server
PORT=3000
HOST=0.0.0.0

# Cryptographic secret used to sign admin JWTs. CHANGE THIS in production.
APP_SECRET=dev-insecure-secret-change-me

# Seed admin credentials (used only when the admin table is empty)
ADMIN_USER=admin
ADMIN_PASSWORD=admin

# SQLite database file location (relative to the server package). Default: server/data/flipblog.db
DB_PATH=data/flipblog.db

# Automatic startup backups. Before pending migrations run, the live database is
# snapshotted (via VACUUM INTO) into a sibling `backups/` directory so a failed
# upgrade can be rolled back. Disable with DB_BACKUP_ENABLED=false. No backups
# are taken for :memory: or test (NODE_ENV=test) databases.
DB_BACKUP_ENABLED=true
# Override the backup directory (default: <dir of DB_PATH>/backups)
# DB_BACKUP_DIR=
# How many recent backups to keep (default: 5)
# DB_BACKUP_RETENTION=5
