# Dependencies
node_modules/
.pnp/
.pnp.js

# Build output (front-end is built into server/public)
server/public/

# Runtime data & uploaded media
server/data/
server/public/uploads/

# Defense-in-depth: if the server is ever launched from server/ instead of the
# repo root, relative storage paths can nest (server/server/public/uploads). The
# real fix is config.js resolving paths from the server root; this rule just
# keeps the resulting junk out of version control.
server/server/

# Environment
.env
.env.local
*.local

# Logs
npm-debug.log*
*.log
*.err

# Editor / OS
.DS_Store
.idea/
.vscode/

# Test artifacts
coverage/
playwright-report/
test-results/
